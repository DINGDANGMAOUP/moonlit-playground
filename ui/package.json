{
  "name": "@moonlit/playground-ui",
  "version": "0.0.1",
  "private": true,
  "description": "Moonlit Playground 的 Halo Console 与前台界面",
  "author": "dingdangmaoup",
  "repository": {
    "type": "git",
    "url": "https://github.com/DINGDANGMAOUP/moonlit-playground.git"
  },
  "homepage": "https://github.com/DINGDANGMAOUP/moonlit-playground",
  "bugs": {
    "url": "https://github.com/DINGDANGMAOUP/moonlit-playground/issues"
  },
  "type": "module",
  "scripts": {
    "build": "run-p type-check build:console build:frontend",
    "build-only": "run-p build:console build:frontend",
    "build:console": "rsbuild build",
    "build:frontend": "rsbuild build --config rsbuild.frontend.config.mjs",
    "dev": "run-p dev:console dev:frontend",
    "dev:console": "rsbuild build --watch --env-mode development",
    "dev:frontend": "rsbuild build --watch --env-mode development --config rsbuild.frontend.config.mjs",
    "test:unit": "vitest run",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@codemirror/lang-css": "6.3.1",
    "@codemirror/lang-html": "6.4.11",
    "@codemirror/lang-javascript": "6.2.5",
    "@codemirror/language": "6.12.4",
    "@codemirror/state": "6.7.1",
    "@codemirror/view": "6.43.6",
    "@codesandbox/sandpack-client": "2.19.8",
    "@halo-dev/ui-shared": "^2.25.2",
    "@lezer/highlight": "1.2.3",
    "codemirror": "6.0.2",
    "lucide": "0.468.0",
    "vue": "^3.5.28"
  },
  "devDependencies": {
    "@halo-dev/richtext-editor": "^2.25.2",
    "@halo-dev/ui-plugin-bundler-kit": "^2.25.2",
    "@iconify-json/mdi": "^1.2.3",
    "@rsbuild/core": "^1.7.3",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^24.13.1",
    "@vue/tsconfig": "^0.8.1",
    "jsdom": "^26.1.0",
    "npm-run-all2": "^7.0.2",
    "typescript": "~5.8.3",
    "unplugin-icons": "^23.0.1",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.3.3"
  },
  "packageManager": "pnpm@11.12.0"
}
